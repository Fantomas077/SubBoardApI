@page "/category/create"
@using SubBoard.Application.Dtos.Category
@using SubBoard.Blazor.Services
@using SubBoard.Domain.Entities
@using MudBlazor
@inject ISnackbar Snackbar

@inject CategoryService CategoryService
@inject NavigationManager _Nav

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-black bg-gradient m-l-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Create Category</h2>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <EditForm Model="form" OnValidSubmit="Submit">
            <DataAnnotationsValidator />
            <ValidationSummary />


            <div class="border p-3 mt-4">
                <div class="form-floating py-3 col-12">
                    <InputText class="form-control" @bind-Value="form.Name" id="Name" />
                    <label>Name</label>
                    <ValidationMessage For="() => form.Name" />
                </div>
                <div class="form-floating py-3 col-12">
                    <InputText class="form-control" @bind-Value="form.Icon" id="Icon" />
                    <label>Emoji</label>
                    <ValidationMessage For="() => form.Icon" />
                </div>

                <div class="d-flex gap-3 p-4">
                    <button type="submit" class="btn btn-primary" disabled="@IsProcessing">
                        <i class="bi bi-save2-fill"></i> @(IsProcessing ? "Processing..." :"Create")
                    </button>

                    <a href="/category" class="btn btn-secondary"> <i class="bi bi-skip-backward-fill"></i> Back to Category</a>
                </div>
            </div>


        </EditForm>
    </div>
</div>


@code {
    private bool IsProcessing;
    public CreateCategoryDto form = new (); 
  


    private async Task Submit()
    {
        IsProcessing = true;
        await Task.Delay(1000);
        await CategoryService.CreateAsync(form);
        Snackbar.Add("Category created successfully!", Severity.Success);
        _Nav.NavigateTo("/categories");

    }
}
